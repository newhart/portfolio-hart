---
import { getMessages, type Locale } from "../i18n/ui";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getMessages(lang);
---

<div
  id="toast-success"
  class="hidden fixed bottom-6 right-6 z-50 w-80 max-w-[calc(100vw-3rem)] bg-white dark:bg-gray-900 rounded-xl shadow-2xl border border-gray-100 dark:border-neutral-800 overflow-hidden translate-x-full transition-transform duration-300 ease-out"
  role="alert"
  aria-live="polite"
>
  <div class="flex items-start gap-3 p-4">
    <div
      class="shrink-0 size-9 rounded-full bg-green-100 dark:bg-green-900/40 flex items-center justify-center"
    >
      <svg
        class="size-5 text-green-600 dark:text-green-400"
        fill="currentColor"
        viewBox="0 0 20 20"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
          clip-rule="evenodd"
        ></path>
      </svg>
    </div>
    <p class="flex-1 text-sm font-medium text-gray-800 dark:text-gray-100 self-center">
      {t.contactForm.successMessage}
    </p>
    <button
      id="close-toast-success"
      aria-label={t.contactForm.continue}
      class="shrink-0 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors"
    >
      <svg class="size-4" fill="currentColor" viewBox="0 0 384 512" aria-hidden="true">
        <path
          d="M342.6 150.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L192 210.7 86.6 105.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L146.7 256 41.4 361.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L192 301.3 297.4 406.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L237.3 256 342.6 150.6z"
        ></path>
      </svg>
    </button>
  </div>
  <div class="h-0.5 bg-gray-100 dark:bg-neutral-800">
    <div data-bar class="h-full bg-green-500 w-full"></div>
  </div>
</div>

<script>
  import { hideToast } from "../utils/toast";

  document.getElementById("close-toast-success")?.addEventListener("click", () => {
    hideToast("toast-success");
  });
</script>
