---
import background from "../assets/background.svg";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import "../styles/global.css";
import {
  defaultLocale,
  getMessages,
  resolveLocaleFromPath,
  type Locale,
} from "../i18n/ui";

interface Props {
  lang?: Locale;
}

const lang = Astro.props.lang ?? resolveLocaleFromPath(Astro.url.pathname);
const t = getMessages(lang ?? defaultLocale);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/webp" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{t.metaTitle}</title>

    <!-- Metas -->
    <meta
      name="description"
      content={t.metaDescription}
    />
  </head>
  <body class="dark:bg-gray-950">
    <img
      class="fixed top-0 left-0 size-full -z-10 blur-2xl"
      src={background.src}
      alt=""
      fetchpriority="high"
    />
    <Navbar lang={lang} />
    <main class="max-w-screen-lg mx-auto p-6 flex flex-col gap-12">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
  <style is:global>
    * {
      scroll-behavior: smooth;
    }
  </style>
</html>
